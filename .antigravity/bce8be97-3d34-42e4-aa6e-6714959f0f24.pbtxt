    replacement_chunks {
      replacement_content: "import { Project } from \'./types\';\n\nexport const NGO_DETAILS = {\n  name: \"MOVE\",\n  fullName: \"Pertubuhan Sukarelawan Harapan Malaysia\",\n  foundedYear: 2015,\n  regNo: \"PPM-023-14-12112015\",\n  address: \"Level 3, Bangunan Sukarelawan, Jalan Sultan Hishamuddin, 50050 Kuala Lumpur, Malaysia\",\n  phone: \"+60 3-2274 9088\",\n  email: \"hello@move-voluntary.org\",\n  socials: {\n    facebook: \"https://facebook.com/movevoluntary\",\n    instagram: \"https://instagram.com/move_voluntary\",\n    linkedin: \"https://linkedin.com/company/move-volunteer\",\n  }\n};\n\nexport const PROJECTS_DATA: Project[] = [\n  {\n    id: \"proj_1\",\n    title: \"Changkat Orang Asli Community Co-Creation\",\n    category: \"Community\",\n    location: \"Local\",\n    country: \"Malaysia (Perak)\",\n    description: \"Collaborating with local Orang Asli families in Perak to co-create solar-powered study huts, design organic micro-gardens, and establish children\'s reading circles.\",\n    details: \"This signature domestic program partners with local village elders (Tok Batin) in Perak. Volunteers stay in home-stays, experiencing local life while co-building sustainable education infrastructure for remote children. We avoid standard \'savior\' dynamics and focus on knowledge-exchange and joint building.\",\n    duration: \"14 Days\",\n    spotsLeft: 5,\n    image: \"https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 650 (Covers meals, homestay, construction supplies)\",\n    partnerName: \"Changkat Semesta Action Group & Tok Batin Association\",\n    skillsNeeded: [\"Basic Construction\", \"Storytelling\", \"Arts & Crafts\", \"Malay conversational\"]\n  },\n  {\n    id: \"proj_2\",\n    title: \"Borneo Marine Protection & Reef Seeding\",\n    category: \"Environment\",\n    location: \"Local\",\n    country: \"Malaysia (Sabah)\",\n    description: \"Reef rehabilitation, beach clean-ups, and building eco-bricks with the oceanic communities of Semporna.\",\n    details: \"Partnering with Sabahan marine biologists and sea-gypsy (Bajau Laut) community advocates, volunteers learn coral propagation methods, engage in daily diving/snorkeling reef cleanups, and run plastic-repurpose workshops for youths.\",\n    duration: \"21 Days\",\n    spotsLeft: 4,\n    image: \"https://images.unsplash.com/photo-1546026423-cc4642628d2b?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 1,200 (Covers marine gear rental, island lodging, boat transfers)\",\n    partnerName: \"Borneo Ocean Conservancy Group\",\n    skillsNeeded: [\"Snorkeling / Swimming\", \"Basic Marine Science Interest\", \"Eco-brick facilitation\"]\n  },\n  {\n    id: \"proj_3\",\n    title: \"Batik & Cultural Heritage Revival Exchange\",\n    category: \"Culture\",\n    location: \"Local\",\n    country: \"Malaysia (Kelantan)\",\n    description: \"Preserving Kelantanese traditional arts while creating global digital marketing frameworks with local artisans.\",\n    details: \"Youth volunteers work directly with heritage weavers and batik designers in Kelantan. This program aims to teach volunteers authentic craft skills while together developing e-commerce websites and creative media portfolios to expand the artisans\' global outreach.\",\n    duration: \"10 Days\",\n    spotsLeft: 8,\n    image: \"https://images.unsplash.com/photo-1513364776144-60967b0f800f?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 500 (Covers loom rental, workshop materials, village stay)\",\n    partnerName: \"Kelantan Heritage Artisan Guild\",\n    skillsNeeded: [\"Graphic Design / Marketing\", \"Photography\", \"Deep Respect for Tradition\", \"English teaching\"]\n  },\n  {\n    id: \"proj_4\",\n    title: \"Siem Reap Eco-Water and Solar Installation\",\n    category: \"Environment\",\n    location: \"International\",\n    country: \"Cambodia\",\n    description: \"Co-installing sand filtration units and simple solar charging boards with rural Cambodian school partners.\",\n    details: \"MOVE\'s longest running international venture. We work in tandem with provincial teachers to ensure remote classrooms maintain clean drinking water and active solar lanterns for nighttime reading circles.\",\n    duration: \"12 Days\",\n    spotsLeft: 6,\n    image: \"https://images.unsplash.com/photo-1542810634-71277d95dcbb?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 1,850 (Includes regional flights, local transfers, visa, materials)\",\n    partnerName: \"Siem Reap Water Hope Initiative\",\n    skillsNeeded: [\"Basic Engineering / Carpentry\", \"Children engagement\", \"English fluency\"]\n  },\n  {\n    id: \"proj_5\",\n    title: \"Lombok Organic Farm and Youth Empowerment\",\n    category: \"Community\",\n    location: \"International\",\n    country: \"Indonesia (Lombok)\",\n    description: \"Engaging in agricultural knowledge transfer and youth leadership academies with local disaster-rebuild schools.\",\n    details: \"Following earthquake recovery programs, MOVE offers co-created training tracks in sustainable farming, digital storytelling, English language modules, and teamwork bootcamps to build local rural resilience.\",\n    duration: \"18 Days\",\n    spotsLeft: 7,\n    image: \"https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 1,600 (Includes ferry, camp accommodation, organic seeds, food)\",\n    partnerName: \"Lombok Bangkit Cooperatives\",\n    skillsNeeded: [\"Agricultural interest\", \"Leadership training\", \"Indonesian/Malay language similarities\"]\n  },\n  {\n    id: \"proj_6\",\n    title: \"Kyoto Intercultural Preservation Initiative\",\n    category: \"Culture\",\n    location: \"International\",\n    country: \"Japan (Kyoto)\",\n    description: \"Assisting local conservationists in restoring historic walking trails, botanical reserves, and temple gardens.\",\n    details: \"An immersive East-Asia exchange designed to blend Malaysian volunteer energy with Japanese Zen horticulture and ecosystem stewardship. In exchange, volunteers participate in local culinary and traditional exchange evenings.\",\n    duration: \"14 Days\",\n    spotsLeft: 3,\n    image: \"https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?auto=format&fit=crop&q=80&w=600\",\n    cost: \"RM 3,200 (Includes cultural accommodation, bullet train passes, tools)\",\n    partnerName: \"Kyoto Eco Preservation Society\",\n    skillsNeeded: [\"Physical fitness\", \"Photography\", \"Conversational Japanese is a major plus\"]\n  }\n];\n\nexport const TESTIMONIALS_DATA = [\n  {\n    name: \"Shazwan bin Halim\",\n    age: 24,\n    role: \"Voluntary Lead in Semporna Project\",\n    text: \"Co-creating the reef propagation program in Semporna was truly empowering. MOVE doesn\'t just deposit volunteers; we listen to the Bajau residents, share meals, and build together as equals. It taught me true empathy and sustainable leadership.\",\n    project: \"Borneo Marine Protection & Reef Seeding\"\n  },\n  {\n    name: \"Elena Rostova\",\n    age: 26,\n    role: \"International Volunteer (Russia)\",\n    text: \"PERTUBUHAN SUKARELAWAN HARAPAN MALAYSIA makes global exchange feel humble and incredibly effective. I learned practical wood building from Perak\'s Orang Asli elders and was able to share digital arts with local students. Highly structured yet deeply personal.\",\n    project: \"Changkat Orang Asli Community Co-Creation\"\n  },\n  {\n    name: \"Encik Ramlan\",\n    age: 48,\n    role: \"Community Partner & Village Council President\",\n    text: \"Other NGOs come and go, but MOVE stays, co-creates, and ensures local people are driving the programs. The educational study huts they built with us are fully managed by our youth now. That is real development.\",\n    project: \"Changkat Orang Asli Community Co-Creation\"\n  }\n];\n\nexport const STATISTICS_DATA = [\n  { value: \"10+\", label: \"Years of Active Service\" },\n  { value: \"4,200+\", label: \"Youth Volunteers mobilized\" },\n  { value: \"48+\", label: \"Impact Projects Co-created\" },\n  { value: \"150,000+\", label: \"Community service hours\" },\n  { value: \"RM 850k+\", label: \"Direct development aid delivered\" }\n];\n\nexport const CORE_VALUES = [\n  {\n    title: \"Co-Creation\",\n    description: \"We never enforce solutions. Every single program is planned and built hand-in-hand with local Malaysian & international grassroots partners.\"\n  },\n  {\n    title: \"Reciprocal Growth\",\n    description: \"Volunteering is not charity\342\200\224it is exchange. Volunteers learn invaluable ancestral wisdom, language, and grit, while communities gain support.\"\n  },\n  {\n    title: \"Inclusivity & Hope\",\n    description: \"As Harapan Malaysia, we believe hope is active. We bridge ethnic, cultural, and national divides to generate lasting global synergy.\"\n  }\n];\n\nexport const FAQS_DATA = [\n  {\n    q: \"Who can apply as a volunteer?\",\n    a: \"Anyone aged 18 to 35 with a passion for learning, humbleness, and structured teamwork. For home projects, conversational Malay is helpful but not mandatory. For international projects, English fluency is preferred.\"\n  },\n  {\n    q: \"Is there a program fee? why?\",\n    a: \"Yes, our programs operate on a strict self-funded model to ensure 100% of donor contributions go directly to building school materials, solar cells, or plant propagation. Program fees cover your lodging, local rural home-stay meals, project insurance, and basic building materials.\"\n  },\n  {\n    q: \"How does the donation portal work?\",\n    a: \"Donations are processed via secure simulation channels in this portal. 100% of public funds are transparently assigned to specific community materials (like sand filters, paint, books, solar panels) which you can track in real-time.\"\n  },\n  {\n    q: \"What does \'Pertubuhan Sukarelawan Harapan Malaysia\' mean?\",\n    a: \"It is our official registered Malaysian NGO name. It translates to \'Volunteers of Hope Association Malaysia\', representing our faith in youth-led active development.\"\n  }\n];\n"
    }
