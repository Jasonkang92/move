          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Volunteering is not charity\342\200\224it is exchange. Volunteers learn invaluable ancestral wisdom, language, and grit, while communities gain support.\""
