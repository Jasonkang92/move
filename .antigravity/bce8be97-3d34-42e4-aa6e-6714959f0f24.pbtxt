        lines {
          text: "    q: \"How does the donation portal work?\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    a: \"Donations are processed via secure simulation channels in this portal. 100% of public funds are transparently assigned to specific community materials (like sand filters, paint, books, solar panels) which you can track in real-time.\""
